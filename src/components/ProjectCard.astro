---
export interface Props {
  title: string;
  client: string;
  category: string;
  categoryColor: string;
  slug: string;
  thumb: string;
  year?: string | number;
  featured?: boolean;
}
const { title, client, category, categoryColor, slug, thumb, year, featured } = Astro.props;
---

<a href={`/work/${slug}`} class:list={['card', { 'card--featured': featured }]} data-hover>
  <div class="card-media">
    <img src={thumb} alt={title} loading="lazy" />
    <div class="card-overlay"></div>
    <div class="card-badge" style={`background:${categoryColor}`}>{category}</div>
  </div>
  <div class="card-info">
    <span class="card-client">{client}</span>
    <span class="card-title">{title}</span>
    {year && <span class="card-year">{year}</span>}
  </div>
</a>

<style>
.card {
  display: block;
  position: relative;
  overflow: hidden;
  background: #111;
  break-inside: avoid;
  margin-bottom: 4px;
}

.card-media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 16/10;
}
.card--featured .card-media { aspect-ratio: 16/9; }

.card-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  filter: brightness(0.85);
}
.card:hover .card-media img {
  transform: scale(1.06);
  filter: brightness(1);
}

.card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.3s;
}
.card:hover .card-overlay { opacity: 1; }

.card-badge {
  position: absolute;
  top: 12px;
  right: 12px;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #000;
  padding: 4px 10px;
  border-radius: 100px;
  opacity: 0;
  transform: translateY(-4px);
  transition: opacity 0.2s, transform 0.2s;
}
.card:hover .card-badge { opacity: 1; transform: translateY(0); }

.card-info {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 8px;
  padding: 10px 4px 4px;
}

.card-client {
  font-size: 0.65rem;
  font-weight: 400;
  color: rgba(255,255,255,0.4);
  font-style: italic;
  white-space: nowrap;
}
.card-title {
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--white);
  text-align: right;
  flex: 1;
}
.card-year {
  font-size: 0.6rem;
  color: rgba(255,255,255,0.3);
  white-space: nowrap;
}
</style>
