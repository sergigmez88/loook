---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Life — LOOOK Studio">
  <Nav page="life" />

  <main class="lf">

    <!-- ═══ LABEL ═══ -->
    <span class="lf-label" data-reveal>2016 — WENEVERLOOKBACK — MANIFESTO</span>

    <!-- ═══ HERO TITLE ═══ -->
    <h1 class="lf-hero" data-reveal>
      Citizens of<br/>
      <em class="serif lime">nowhere</em><span class="lime">.</span>
    </h1>

    <!-- ═══ LEAD ═══ -->
    <p class="lf-lead" data-reveal>
      We are citizens of <em class="serif lime">nowhere</em> — and that's exactly the point.<br/>
      We belong to the moment, to the frame, to the story being told right now.
    </p>

    <!-- ═══ HORIZONTAL 1 ═══ -->
    <div class="lf-wide" data-reveal>
      <img class="lf-wide-holder" src="/life/still-01.jpg" alt="" loading="lazy" decoding="async"/>
      <span class="lf-img-cap">FRAME 01</span>
    </div>

    <!-- ═══ PULL QUOTE A ═══ -->
    <p class="lf-pull" data-reveal>
      So why don't you <em class="serif lime">think</em>,<br/>
      <em class="serif lime">jump</em>, <em class="serif lime">fight</em>, <em class="serif lime">fly</em>?
    </p>

    <!-- ═══ IMAGE PAIR — 2 VERTICALS ═══ -->
    <div class="lf-duo">
      <div class="lf-duo-a" data-reveal>
        <img class="lf-duo-holder" src="/life/still-02.jpg" alt="" loading="lazy" decoding="async"/>
        <span class="lf-img-cap">FRAME 02</span>
      </div>
      <div class="lf-duo-b" data-reveal data-delay=".12">
        <img class="lf-duo-holder" src="/life/still-03.jpg" alt="" loading="lazy" decoding="async"/>
        <span class="lf-img-cap">FRAME 03</span>
      </div>
    </div>

    <!-- ═══ BODY ═══ -->
    <p class="lf-body" data-reveal>
      Dance, sweat, burn it all out. There is nothing to lose,<br/>
      and <em class="serif">everything</em> to change.
    </p>

    <!-- ═══ HORIZONTAL 2 ═══ -->
    <div class="lf-wide lf-wide--right" data-reveal>
      <img class="lf-wide-holder" src="/life/still-04.jpg" alt="" loading="lazy" decoding="async"/>
      <span class="lf-img-cap">FRAME 04</span>
    </div>

    <!-- ═══ PULL QUOTE B ═══ -->
    <p class="lf-pull lf-pull--right" data-reveal>
      Chase your goals —<br/>
      <em class="serif">but don't<br/>miss the ride.</em>
    </p>

    <!-- ═══ HORIZONTAL 3 ═══ -->
    <div class="lf-wide lf-wide--narrow" data-reveal>
      <img class="lf-wide-holder" src="/life/still-05.jpg" alt="" loading="lazy" decoding="async"/>
      <span class="lf-img-cap">FRAME 05</span>
    </div>

    <!-- ═══ BODY SMALL ═══ -->
    <p class="lf-body lf-body--small" data-reveal>
      That's the real secret. Everyone loses, and <em class="serif lime">everyone wins</em>.<br/>
      Think like a person who truly believes they can do anything they set their mind to.<br/>
      Make something you'll <em class="serif lime">remember</em>. Then move — because movement is life,<br/>
      and this life is yours.
    </p>

    <!-- ═══ MID STATEMENT ═══ -->
    <p class="lf-mid" data-reveal>
      Be <em class="serif lime">here</em>.<br/>
      Be <em class="serif lime">present</em>.
    </p>

    <!-- ═══ FINALE ═══ -->
    <div class="lf-finale" data-reveal>
      <span class="lf-finale-pre">And never</span>
      <h2 class="lf-finale-mark">LOOOK <em class="serif lime">back.</em></h2>
    </div>

  </main>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>('[data-delay]').forEach((el) => {
    el.style.transitionDelay = `${el.dataset.delay}s`;
  });
  const io = new IntersectionObserver((es) => {
    es.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -30px 0px' });
  document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
</script>

<style>
.lf {
  --bg: #14160e; --ink: #e9ece0; --lime: #E84010;
  --serif: 'Fraunces', Georgia, serif; --mono: 'Space Mono', monospace;
  background: var(--bg); color: var(--ink);
  padding: 22vh 8vw 18vh;
  max-width: 1400px; margin: 0 auto;
}
.serif { font-family: var(--serif); font-weight: 400; font-style: italic; }
.lime  { color: var(--lime); }

[data-reveal] {
  opacity: 0; transform: translateY(24px);
  transition: opacity 1s cubic-bezier(.2,.8,.2,1), transform 1s cubic-bezier(.2,.8,.2,1);
}
[data-reveal].in { opacity: 1; transform: none; }

/* ═══ LABEL ═══ */
.lf-label {
  display: block;
  font-family: var(--mono); font-size: .58rem; font-weight: 700;
  letter-spacing: .26em; text-transform: uppercase;
  color: rgba(233,236,224,.35);
  margin-bottom: 6vh;
}

/* ═══ HERO ═══ */
.lf-hero {
  font-size: clamp(4.5rem, 14vw, 15rem); font-weight: 900;
  letter-spacing: -.048em; line-height: .88;
  margin-bottom: 7vh;
}
.lf-hero .serif { font-weight: 400; }

/* ═══ LEAD ═══ */
.lf-lead {
  font-size: clamp(1rem, 1.9vw, 1.55rem); font-weight: 300;
  line-height: 1.65; color: rgba(233,236,224,.5);
  max-width: 48ch;
  margin-bottom: 10vh;
}
.lf-lead .serif { font-weight: 400; }

/* ═══ PULL QUOTES ═══ */
.lf-pull {
  font-size: clamp(2.4rem, 7vw, 7.2rem); font-weight: 800;
  letter-spacing: -.035em; line-height: 1.0;
  margin-bottom: 10vh;
}
.lf-pull .serif { font-weight: 400; }
.lf-pull--right {
  text-align: right;
  margin-left: auto; margin-right: 0;
  max-width: 18ch;
}

/* ═══ IMAGE CAPTION ═══ */
.lf-img-cap {
  display: block;
  font-family: var(--mono); font-size: .48rem; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  color: rgba(233,236,224,.25);
  margin-top: 10px;
}

/* ═══ DUO — 2 VERTICALS ═══ */
.lf-duo {
  display: flex;
  align-items: flex-start;
  gap: 18px;
  margin: 0 0 12vh;
  width: 72%;
  margin-left: auto;
}
.lf-duo-a { width: 52%; flex-shrink: 0; }
.lf-duo-b { width: 48%; flex-shrink: 0; margin-top: 8vh; }
.lf-duo-holder {
  width: 100%; aspect-ratio: 2/3;
  object-fit: cover; display: block;
}

/* ═══ WIDE — HORIZONTALS ═══ */
.lf-wide {
  width: 88%;
  margin: 0 0 16vh;
}
.lf-wide--right {
  margin-left: auto; margin-right: 0;
  width: 72%;
}
.lf-wide--narrow {
  width: 60%;
}
.lf-wide-holder {
  width: 100%; aspect-ratio: 16/9;
  object-fit: cover; display: block;
}

/* ═══ BODY ═══ */
.lf-body {
  font-size: clamp(1.5rem, 3.4vw, 3.2rem); font-weight: 700;
  letter-spacing: -.022em; line-height: 1.22;
  max-width: 22ch;
  margin-bottom: 10vh;
}
.lf-body .serif { font-weight: 400; color: rgba(233,236,224,.8); }
.lf-body.lf-body--small {
  font-size: clamp(.9rem, 1.5vw, 1.2rem); font-weight: 400;
  line-height: 1.72; color: rgba(233,236,224,.45);
  max-width: 52ch; letter-spacing: 0;
}
.lf-body--small .serif { color: rgba(233,236,224,.7); }

/* ═══ MID STATEMENT ═══ */
.lf-mid {
  font-size: clamp(3rem, 9vw, 10rem); font-weight: 900;
  letter-spacing: -.04em; line-height: .92;
  margin-bottom: 22vh;
}
.lf-mid .serif { font-weight: 400; }

/* ═══ FINALE ═══ */
.lf-finale { text-align: right; }
.lf-finale-pre {
  display: block;
  font-family: var(--mono); font-size: clamp(.6rem, 1.4vw, .9rem); font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  color: rgba(233,236,224,.35); margin-bottom: 14px;
}
.lf-finale-mark {
  font-size: clamp(3rem, 7vw, 8rem); font-weight: 900;
  letter-spacing: -.05em; line-height: .88;
}
.lf-finale-mark .serif { font-weight: 400; }

/* ═══ RESPONSIVE ═══ */
@media (max-width: 820px) {
  .lf { padding: 18vh 6vw 14vh; }
  .lf-duo { width: 90%; }
  .lf-wide { width: 100%; }
  .lf-pull--right { margin-left: 0; text-align: left; }
}
@media (max-width: 520px) {
  .lf { padding: 16vh 5vw 12vh; }
  .lf-duo { width: 100%; flex-direction: column; }
  .lf-duo-a, .lf-duo-b { width: 100%; }
  .lf-duo-b { margin-top: 16px; }
}
</style>
