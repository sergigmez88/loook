---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { projects } from '../content/projects';
import { resolveImg } from '../utils/resolveImg';

const heroMedia = 'https://images.unsplash.com/photo-1485846234645-a62644f84728?w=1920&q=85';

// Selected work (grid irregular) — hardcoded order
const featuredSlugs = [
  'dazn-scalpers',
  'usc-drone-cities',
  'gearing-up-suzuki',
  'comtoyou-saudi',
  'usc-heroes-jonan',
  'marmota-hay-que-dormir-mas',
];
const featured = featuredSlugs.map(s => projects.find(p => p.slug === s)!).filter(Boolean);

---

<BaseLayout title="LOOOK Studio — Creative Film Studio" siteBar={false}>
  <Nav />

  <!-- ═══ LOADER ═══ -->
  <div id="ld" class="ld" aria-hidden="true">
    <div class="ld-top">
      <span class="ld-sys">SYS · <span id="ldCount">000</span></span>
      <span class="ld-tag">► LOOOK.SYS</span>
    </div>
    <div class="ld-mid">
      <div class="ld-jump">
        <svg class="ld-eye" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M50 18 C18 18 4 50 4 50 C4 50 18 82 50 82 C82 82 96 50 96 50 C96 50 82 18 50 18 Z"
                fill="none" stroke="white" stroke-width="4.5" stroke-linejoin="round"/>
          <circle cx="50" cy="50" r="21" fill="none" stroke="white" stroke-width="3"/>
          <ellipse cx="50" cy="50" rx="10" ry="21" fill="none" stroke="white" stroke-width="2.2"/>
          <ellipse cx="50" cy="50" rx="21" ry="8.5" fill="none" stroke="white" stroke-width="2.2"/>
          <line x1="29" y1="50" x2="71" y2="50" stroke="white" stroke-width="2.2"/>
          <line x1="50" y1="29" x2="50" y2="71" stroke="white" stroke-width="2.2"/>
        </svg>
      </div>
      <span class="ld-name">LOOOK STUDIO</span>
    </div>
    <div class="ld-bar"><div class="ld-fill" id="ldFill"></div></div>
  </div>

  <div class="scroll-prog"><div class="scroll-prog-bar" id="progBar"></div></div>

  <main class="lp">

    <!-- ═══ 1 · STAGE (reel → se encoge) ═══ -->
    <section class="stage" id="stage">
      <div class="stage-pin">
        <!-- marquee detrás -->
        <div class="stage-mq" id="stageMq" aria-hidden="true">
          <div class="mq-row mq-a"><span>WE CAPTURE WHAT MOVES ✦ WE CAPTURE WHAT MOVES ✦ WE CAPTURE WHAT MOVES ✦ </span></div>
          <div class="mq-row mq-b"><span>MAKE SOMETHING YOU'LL REMEMBER ✦ MAKE SOMETHING YOU'LL REMEMBER ✦ </span></div>
        </div>

        <!-- reel -->
        <div class="stage-reel" id="stageReel">
          <img class="stage-img" src={heroMedia} alt=""/>
          <video class="stage-vid" autoplay muted loop playsinline poster={heroMedia}><source src="/reel.mp4" type="video/mp4"/></video>
          <div class="stage-reel-tint"></div>
        </div>

        <!-- tagline abajo del reel (pequeña) -->
        <div class="stage-intro" id="stageIntro">
          <span class="stage-sub">CREATIVE FILM STUDIO</span>
        </div>

        <div class="stage-scroll" id="stageScroll"><span>SCROLL</span><span class="ss-line"></span></div>
      </div>
    </section>

    <!-- ═══ 2 · STATEMENT (serif/sans) ═══ -->
    <section class="stm">
      <p class="stm-eye" data-reveal>LOOOK — CREATIVE FILM STUDIO · BARCELONA</p>
      <h2 class="stm-big" data-reveal>
        <span class="serif lime">Redefining</span> the frame,
        chasing the <span class="serif lime">light</span>, and turning
        <span class="serif lime">motion</span> into emotion —
        a studio built on stories, in film and beyond.
      </h2>
    </section>

    <!-- ═══ 3 · SELECTED WORK ═══ -->
    <section class="sel">
      <div class="sel-head">
        <h2 class="sel-h"><span class="serif lime">Selected</span> work</h2>
        <a href="/work" class="sel-all" data-reveal data-hover>ALL PROJECTS ↗</a>
      </div>
      <div class="sel-grid">
        {featured.map((p, i) => (
          <a class:list={['si', `si-${i}`]} href={`/work/${p.slug}`} data-hover data-cursor="VIEW" data-reveal>
            <img src={resolveImg(p.thumb)} alt={p.title} loading="lazy" decoding="async"/>
            {p.preview && <video class="si-prev" src={p.preview} muted loop playsinline preload="auto"></video>}
            <div class="si-bar"><span class="si-l">{p.format}</span><span class="si-t">{p.title}</span><span class="si-r">{p.client}</span></div>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══ 4 · MANIFESTO ═══ -->
    <section class="mani">
      <span class="mani-eye" data-reveal>LIFE / MANIFESTO</span>
      <blockquote class="mani-q" data-reveal>“Citizens of nowhere —<br><em class="serif">why don't you think, jump, fly.”</em></blockquote>
      <a href="/life" class="mani-link" data-reveal data-hover>READ THE MANIFESTO <span>→</span></a>
    </section>

    <!-- ═══ 5 · FOOTER (estilo Lando) ═══ -->
    <footer class="ft">
      <div class="ft-frame">
        <div class="ft-top">

          <h2 class="ft-head">
            <span class="sans">LET'S MAKE SOMETHING</span><br>
            <em class="serif lime">you'll remember.</em>
          </h2>
        </div>

        <a href="mailto:hello@loook.studio" class="ft-enq" data-hover>SAY HI <span>↗</span></a>

        <div class="ft-bottom">
          <span>© MMXXVI LOOOK STUDIO · ALL RIGHTS RESERVED</span>
        </div>
      </div>
    </footer>

  </main>
</BaseLayout>

<script>
  // ── LOADER ──
  const ld = document.getElementById('ld');
  const ldCount = document.getElementById('ldCount') as HTMLElement;
  const ldFill = document.getElementById('ldFill') as HTMLElement;
  if (ld && ldFill) {
    // random variant 0-2
    const v = Math.floor(Math.random() * 3);
    ld.classList.add(`ld-v${v}`);
    let n = 0;
    const interval = setInterval(() => {
      n++;
      if (ldCount) ldCount.textContent = String(n).padStart(3, '0');
      ldFill.style.width = `${n}%`;
      if (n >= 100) {
        clearInterval(interval);
        setTimeout(() => {
          ld.style.opacity = '0';
          setTimeout(() => ld.remove(), 500);
        }, 80);
      }
    }, 8);
  }

  const clamp = (v: number, a: number, b: number) => Math.max(a, Math.min(b, v));
  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
  const easeInOut = (t: number) => (t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2);

  // ── STAGE: reel shrink driven by scroll ──
  const stage = document.getElementById('stage') as HTMLElement;
  const reel = document.getElementById('stageReel') as HTMLElement;
  const mq = document.getElementById('stageMq') as HTMLElement;
  const intro = document.getElementById('stageIntro') as HTMLElement;
  const scrollCue = document.getElementById('stageScroll') as HTMLElement;
  const progBar = document.getElementById('progBar') as HTMLElement;

  const frame = () => {
    const rect = stage.getBoundingClientRect();
    const total = stage.offsetHeight - window.innerHeight;
    const p = total > 0 ? clamp(-rect.top / total, 0, 1) : 0;

    // reel: scale 1 → 0.42 en el primer 60% del scroll
    const sp = easeInOut(clamp(p / 0.6, 0, 1));
    const scale = lerp(1, 0.66, sp);
    reel.style.transform = `scale(${scale})`;
    reel.style.borderRadius = `${sp * 10}px`;

    if (mq) mq.style.opacity = `${clamp((p - 0.2) / 0.3, 0, 1)}`;
    if (intro) intro.style.opacity = `${1 - clamp(p / 0.22, 0, 1)}`;
    if (scrollCue) scrollCue.style.opacity = `${1 - clamp(p / 0.15, 0, 1)}`;

    const max = document.body.scrollHeight - window.innerHeight;
    if (progBar && max > 0) progBar.style.width = `${(window.scrollY / max) * 100}%`;

    requestAnimationFrame(frame);
  };
  requestAnimationFrame(frame);

  // ── reveals ──
  const io = new IntersectionObserver((es) => {
    es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));

  // ── autoplay vídeo al hacer scroll ──
  const vio = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      const v = (e.target as HTMLElement).querySelector('video');
      if (!v) return;
      if (e.isIntersecting) {
        v.play().catch(() => {});
        e.target.classList.add('vid-on');
      } else {
        v.pause();
        e.target.classList.remove('vid-on');
      }
    });
  }, { threshold: 0.25 });
  document.querySelectorAll<HTMLElement>('.si').forEach((el) => vio.observe(el));

</script>

<style>
.lp {
  --bg: #14160e; --ink: #e9ece0; --lime: #E84010;
  --serif: 'Fraunces', Georgia, serif; --mono: 'Space Mono', monospace;
  background: var(--bg); color: var(--ink);
}
.serif { font-family: var(--serif); font-weight: 400; font-style: italic; }
.lime { color: var(--lime); }
.sans { font-family: 'Space Grotesk', sans-serif; }
/* ═══ LOADER ═══ */
.ld { position: fixed; inset: 0; z-index: 900; background: #14160e; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none; transition: opacity .5s ease; }
.ld-top { position: absolute; top: 28px; left: 28px; display: flex; flex-direction: column; gap: 5px; font-family: 'Space Mono', monospace; }
.ld-sys { font-size: .55rem; font-weight: 700; letter-spacing: .2em; color: rgba(233,236,224,.35); text-transform: uppercase; }
.ld-sys span { color: #E84010; }
.ld-tag { font-size: .46rem; font-weight: 700; letter-spacing: .16em; color: rgba(233,236,224,.16); text-transform: uppercase; }
.ld-mid { display: flex; flex-direction: column; align-items: center; gap: 14px; }
.ld-eye { width: 48px; height: 48px; animation: eyePulse 2.4s ease-in-out infinite; }
@keyframes eyePulse { 0%,100% { opacity: .7; transform: scale(.95); } 50% { opacity: 1; transform: scale(1.05); } }
.ld-name { font-family: 'Space Mono', monospace; font-size: .5rem; font-weight: 700; letter-spacing: .26em; color: rgba(233,236,224,.22); text-transform: uppercase; }
.ld-bar { position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background: rgba(233,236,224,.06); }
.ld-fill { height: 100%; width: 0; background: #E84010; }

/* ── Variant A: bounce up ── */
.ld-v0 .ld-jump { animation: ballJump 1s cubic-bezier(.4,0,.2,1) 1 .1s both; }
@keyframes ballJump {
  0%,20%          { transform: translateY(0) scaleX(1) scaleY(1); }
  45%             { transform: translateY(-50px) scaleX(1) scaleY(1); }
  65%             { transform: translateY(-50px) scaleX(1) scaleY(1); }
  82%             { transform: translateY(0) scaleX(1.3) scaleY(.7); }
  92%             { transform: translateY(-12px) scaleX(.9) scaleY(1.1); }
  100%            { transform: translateY(0) scaleX(1) scaleY(1); }
}
/* ── Variant B: pulse only (default dotPulse) ── */
/* ── Variant C: double bounce ── */
.ld-v2 .ld-jump { animation: ballDouble .85s ease-in-out 1 .1s both; }
@keyframes ballDouble {
  0%,100% { transform: translateY(0); }
  22%     { transform: translateY(-34px); }
  40%     { transform: translateY(0); }
  62%     { transform: translateY(-18px); }
  80%     { transform: translateY(0); }
}

.scroll-prog { position: fixed; top: 0; left: 0; width: 100%; height: 2px; background: rgba(255,255,255,.05); z-index: 610; }
.scroll-prog-bar { height: 100%; width: 0; background: var(--lime); }


/* ═══ 1 · STAGE ═══ */
.stage { height: 260vh; position: relative; }
.stage-pin { position: sticky; top: 0; height: 100vh; overflow: hidden; display: flex; align-items: center; justify-content: center; background: var(--bg); }
.stage-mq { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; gap: 2vh; opacity: 0; z-index: 1; pointer-events: none; }
.mq-row { display: flex; white-space: nowrap; }
.mq-row span { font-size: clamp(4rem, 13vw, 15rem); font-weight: 900; letter-spacing: -.03em; line-height: .9; }
.mq-a { animation: mqL 30s linear infinite; color: var(--ink); }
.mq-b { animation: mqR 36s linear infinite; color: transparent; -webkit-text-stroke: 1.5px rgba(233,236,224,.3); }
@keyframes mqL { from { transform: translateX(0); } to { transform: translateX(-50%); } }
@keyframes mqR { from { transform: translateX(-30%); } to { transform: translateX(0); } }

.stage-reel { position: relative; width: 100vw; height: 100vh; transform-origin: center center; z-index: 2; overflow: hidden; will-change: transform; }
.stage-img, .stage-vid { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.stage-vid { z-index: 1; }
.stage-reel-tint { position: absolute; inset: 0; z-index: 2; background: rgba(0,0,0,.25); }
.topo path { vector-effect: non-scaling-stroke; }

.stage-intro { position: absolute; inset: 0; z-index: 4; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; padding-bottom: 9vh; text-align: center; pointer-events: none; }
.stage-sub { font-size: clamp(.5rem, .82vw, .72rem); font-weight: 700; letter-spacing: .42em; color: var(--lime); }
.stage-scroll { position: absolute; bottom: 30px; right: 30px; z-index: 5; display: flex; flex-direction: column; align-items: center; gap: 12px; font-size: .5rem; font-weight: 700; letter-spacing: .35em; color: rgba(255,255,255,.5); }
.ss-line { width: 1px; height: 36px; background: linear-gradient(var(--lime), transparent); transform-origin: top; animation: ssd 2s ease-in-out infinite; }
@keyframes ssd { 0%,100%{transform:scaleY(.5);opacity:.4} 50%{transform:scaleY(1);opacity:1} }

/* ═══ 2 · STATEMENT ═══ */
.stm { padding: 16vh 5vw; }
.stm-eye { font-family: var(--mono); font-size: .62rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: rgba(233,236,224,.4); margin-bottom: 40px; }
.stm-big { font-size: clamp(2rem, 6vw, 5.6rem); font-weight: 700; line-height: 1.06; letter-spacing: -.02em; max-width: 1500px; }
.stm-big .serif { font-size: 1.08em; letter-spacing: -.01em; }

/* reveal */
[data-reveal] { opacity: 0; transform: translateY(34px); transition: opacity .9s cubic-bezier(.2,.8,.2,1), transform .9s cubic-bezier(.2,.8,.2,1); }
[data-reveal].in { opacity: 1; transform: none; }

/* ═══ 3 · SELECTED WORK ═══ */
.sel { padding: 8vh 5vw 16vh; }
.sel-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 5vh; }
.sel-h { font-size: clamp(2.6rem, 7vw, 6.5rem); font-weight: 900; letter-spacing: -.03em; line-height: .9; }
.sel-h .serif { font-weight: 400; }
.sel-all { font-family: var(--mono); font-size: .66rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: var(--ink); border-bottom: 1px solid rgba(233,236,224,.3); padding-bottom: 4px; white-space: nowrap; }
.sel-all:hover { color: var(--lime); border-color: var(--lime); }

.sel-grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: 26vh; gap: 16px; }
.si { position: relative; overflow: hidden; background: #222; display: block; }
.si-0 { grid-column: span 2; grid-row: span 2; }
.si img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.85) brightness(.82); transition: transform .8s cubic-bezier(.2,.8,.2,1), filter .4s; }
.si:hover img { transform: scale(1.05); filter: saturate(1.05) brightness(1); }
.si-prev { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .8s ease; pointer-events: none; }
.si.vid-on .si-prev { opacity: 1; }
.si-bar { position: absolute; left: 0; right: 0; bottom: 0; display: grid; grid-template-columns: 1fr auto 1fr; gap: 8px; align-items: center; padding: 32px 12px 12px; background: linear-gradient(transparent, rgba(0,0,0,.88)); font-family: var(--mono); font-size: .56rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
.si-l { text-align: left; color: rgba(255,255,255,.6); }
.si-t { text-align: center; color: #fff; transition: color .25s; }
.si-r { text-align: right; color: rgba(255,255,255,.6); }
.si:hover .si-t { color: var(--lime); }

/* ═══ 4 · MANIFESTO ═══ */
.mani { background: #f0ede8; color: #000; padding: 7vh 5vw; }
.mani-eye { font-family: var(--mono); font-size: .62rem; font-weight: 700; letter-spacing: .3em; color: rgba(0,0,0,.3); text-transform: uppercase; display: block; margin-bottom: 30px; }
.mani-q { font-size: clamp(1.8rem, 5.5vw, 4.6rem); font-weight: 700; line-height: 1.12; letter-spacing: -.02em; max-width: 18ch; margin-bottom: 40px; }
.mani-q .serif { font-weight: 400; color: rgba(0,0,0,.7); }
.mani-link { display: inline-flex; align-items: center; gap: 11px; font-family: var(--mono); font-size: .66rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; border-bottom: 1px solid rgba(0,0,0,.3); padding-bottom: 4px; }
.mani-link span { transition: transform .25s; } .mani-link:hover span { transform: translateX(5px); }

/* ═══ 5 · FOOTER ═══ */
.ft { background: var(--bg); padding: 14px; }
.ft-frame { padding: 7vh 4vw 26px; position: relative; overflow: hidden; }
.ft-top { position: relative; text-align: center; margin-bottom: 2vh; }
.ft-sign { position: absolute; top: -3vh; left: 50%; transform: translateX(-50%) rotate(-4deg); width: clamp(160px, 22vw, 280px); z-index: 2; }
.ft-head { position: relative; z-index: 1; font-size: clamp(1.2rem, 2.8vw, 2.8rem); font-weight: 900; letter-spacing: -.03em; line-height: .97; text-transform: uppercase; }
.ft-head .serif, .ft-head em.serif { text-transform: none; font-weight: 400; font-style: italic; }
.ft-mid { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 4vw; margin: 2vh 0 5vh; }
.ft-col { display: flex; flex-direction: column; gap: 8px; }
.ft-col-r { align-items: flex-end; text-align: right; }
.ft-label { font-family: var(--mono); font-size: .56rem; font-weight: 700; letter-spacing: .22em; color: rgba(233,236,224,.4); text-transform: uppercase; margin-bottom: 10px; }
.ft-col a { font-size: clamp(1.1rem, 2vw, 1.7rem); font-weight: 700; letter-spacing: -.01em; transition: color .2s; }
.ft-col a:hover { color: var(--lime); }
.ft-portrait { position: relative; width: clamp(260px, 34vw, 500px); aspect-ratio: 16/10; overflow: hidden; border-radius: 4px; }
.ft-portrait img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.8) brightness(.85); }
.ft-portrait-tag { position: absolute; bottom: 12px; left: 12px; font-family: var(--mono); font-size: .55rem; font-weight: 700; letter-spacing: .14em; color: #fff; }
.ft-enq { display: flex; align-items: center; justify-content: center; gap: 10px; background: var(--lime); color: #000; font-family: var(--mono); font-size: .62rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; padding: 11px 28px; border-radius: 100px; max-width: 200px; margin: 4vh auto 5vh; transition: transform .2s; }
.ft-enq:hover { transform: scale(1.02); }
.ft-clients { overflow: hidden; border-top: 1px solid rgba(233,236,224,.12); border-bottom: 1px solid rgba(233,236,224,.12); padding: 16px 0; margin-bottom: 22px; }
.ftc-track { display: flex; white-space: nowrap; gap: 48px; animation: mqL 28s linear infinite; }
.ftc-track span { font-family: var(--mono); font-size: .7rem; font-weight: 700; letter-spacing: .12em; color: rgba(233,236,224,.35); }
.ft-bottom { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; font-family: var(--mono); font-size: .56rem; font-weight: 700; letter-spacing: .12em; color: rgba(233,236,224,.4); text-transform: uppercase; }
.ft-legal { display: flex; gap: 18px; }
.ft-legal a:hover { color: var(--lime); }

/* ═══ RESPONSIVE ═══ */
@media (max-width: 900px) {
  .sel-grid { grid-template-columns: 1fr 1fr; grid-auto-rows: 24vh; }
  .si-0 { grid-column: span 2; grid-row: span 1; }
  .ft-mid { grid-template-columns: 1fr; justify-items: center; text-align: center; gap: 30px; }
  .ft-col, .ft-col-r { align-items: center; text-align: center; }
  .ft-portrait { width: 100%; max-width: 520px; }
  .stage-sign { width: 82%; }
}
@media (max-width: 540px) {
  .sel-grid { grid-template-columns: 1fr; grid-auto-rows: 30vh; }
  .si-0 { grid-column: span 1; }
}
</style>
